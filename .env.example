# ========================================
# Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ========================================

# ========================================
# LLM API Keys & Endpoints
# ========================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6

CRITIC_AGENT_API_KEY=your_qwen_api_key_here
CRITIC_API_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
CRITIC_MODEL=qwen-plus

MEM0_QWEN_API_KEY=your_qwen_api_key_here
MEM0_QWEN_API_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
MEM0_QWEN_MODEL_NAME=qwen-plus

EMBEDDINGS_API_KEY=your_embeddings_api_key_here
EMBEDDINGS_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode
EMBEDDINGS_MODEL_NAME=text-embedding-v3

# ========================================
# External Tools
# ========================================
# Stockfish Service URL (Vercel serverless endpoint)
# After deploying to Vercel, replace with your actual URL
STOCKFISH_SERVICE_URL=http://localhost:3000/api/evaluate
# For production: STOCKFISH_SERVICE_URL=https://your-app.vercel.app/api/evaluate

# DEPRECATED: Path to local Stockfish binary (no longer needed with serverless)
# STOCKFISH_PATH=backend/bin/stockfish/stockfish.exe

# ========================================
# Frontend Configuration (for Next.js)
# ========================================
# Must be prefixed with NEXT_PUBLIC_ to be accessible in browser
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
