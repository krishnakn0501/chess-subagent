# Backend API URL (FastAPI server on Railway)
# Local dev: http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# WebSocket URL (same host as backend)
# Local dev: ws://localhost:8000/ws/game
# NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Stockfish Engine URL (deployed on Vercel - Project B)
# Local dev: http://localhost:3002
NEXT_PUBLIC_ENGINE_URL=http://localhost:3002

NEXT_PUBLIC_WS_URL=ws://localhost:8000
